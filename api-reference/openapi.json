    "/fee-schedule-results/filters": {
      "get": {
        "summary": "Get available filters",
        "description": "Returns all distinct filter values for fee schedule results, scoped to exchanges associated with your API key. Use these values to build valid queries for the list endpoint and to populate UI filter dropdowns.",
