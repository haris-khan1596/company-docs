        "tags": ["Fee Schedule Results"],
        "parameters": [
          {
            "name": "exchange_name",
            "in": "query",
            "required": false,
            "schema": { "type": "array", "items": { "type": "string" } },
            "style": "form",
            "explode": true,
            "description": "Narrow filter values to specific exchange(s). Repeat for multiple: `?exchange_name=fee_cboe_us_bzx_options&exchange_name=fee_memx`"
